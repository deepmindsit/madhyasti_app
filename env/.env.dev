# =========================
# 🌍 APP INFO
# =========================
APP_NAME=Madhyasthi
APP_VERSION=1.0.1
MIN_APP_VERSION=1.0.0
BUILD_NUMBER=1

# =========================
# 🌐 ENVIRONMENT
# =========================
ENV=dev

# =========================
# 🔗 API CONFIG
# =========================
BASE_URL=http://192.168.29.112/madhyasthi/api/v1/
SOCKET_URL=wss://socket.dev.yourapp.com
API_TIMEOUT=30000

# =========================
# 🔐 AUTH CONFIG
# =========================
AUTH_TOKEN_KEY=user_token
REFRESH_TOKEN_KEY=refresh_token

# =========================
# 🔑 API KEYS
# =========================
GOOGLE_API_KEY=your_google_key_here
FIREBASE_API_KEY=your_firebase_key_here
MAP_API_KEY=your_map_key_here

# =========================
# 📦 DATABASE
# =========================
DATABASE_NAME=my_app_db
DATABASE_VERSION=1

# =========================
# 🧠 FEATURE FLAGS
# =========================
ENABLE_LOGGING=true
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
DEBUG_MODE=true
VERBOSE_LOGGING=true

# =========================
# 📡 ANALYTICS
# =========================
ANALYTICS_KEY=dev_analytics_key

# =========================
# 🔔 PUSH NOTIFICATIONS
# =========================
FCM_SENDER_ID=123456789
FCM_TOPIC=dev_users

# =========================
# 🗂️ CACHE CONFIG
# =========================
CACHE_DURATION=3600
MAX_CACHE_ITEMS=100

# =========================
# 📁 FILE UPLOAD
# =========================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=jpg,png,pdf,mp4

# =========================
# 🔄 PAGINATION
# =========================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=50

# =========================
# ⏱️ TIMEOUTS
# =========================
CONNECT_TIMEOUT=15000
RECEIVE_TIMEOUT=15000

# =========================
# 🛡️ SECURITY
# =========================
ENABLE_SSL_PINNING=false
ENCRYPTION_KEY=dev_secret_key

# =========================
# 🌐 LOCALIZATION
# =========================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,mr

# =========================
# 🎨 UI CONFIG
# =========================
ENABLE_DARK_MODE=true
SHOW_DEBUG_BANNER=true