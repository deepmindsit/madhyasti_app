APP_NAME=Madhyasthi
APP_VERSION=1.0.0
MIN_APP_VERSION=1.0.0
BUILD_NUMBER=1

ENV=prod

BASE_URL=https://api.yourapp.com
SOCKET_URL=wss://socket.yourapp.com
API_TIMEOUT=30000

AUTH_TOKEN_KEY=user_token
REFRESH_TOKEN_KEY=refresh_token

GOOGLE_API_KEY=prod_google_key
FIREBASE_API_KEY=prod_firebase_key

DATABASE_NAME=my_app_db
DATABASE_VERSION=1

ENABLE_LOGGING=false
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
DEBUG_MODE=false
VERBOSE_LOGGING=false

ANALYTICS_KEY=prod_analytics_key

FCM_SENDER_ID=123456789
FCM_TOPIC=users

CACHE_DURATION=7200
MAX_CACHE_ITEMS=200

MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=jpg,png,pdf,mp4

DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=50

CONNECT_TIMEOUT=15000
RECEIVE_TIMEOUT=15000

ENABLE_SSL_PINNING=true
ENCRYPTION_KEY=prod_secret_key

DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,mr

ENABLE_DARK_MODE=true
SHOW_DEBUG_BANNER=false